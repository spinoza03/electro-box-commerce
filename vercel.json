{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(.+\\.(png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot|otf))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.js"
    }
  ]
}
